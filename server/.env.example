# =============================================================================
# Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your actual values.
#   cp .env.example .env
#
# NEVER commit your .env file to git — add it to .gitignore!
# =============================================================================

# -----------------------------------------------------------------------------
# AWS Credentials
# These are used by boto3 (AWS SDK) to authenticate with AWS services.
# For local dev: use an IAM user with programmatic access keys.
# For production (ECS): use an IAM Role attached to the ECS Task — no keys needed.
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1

# -----------------------------------------------------------------------------
# AWS Bedrock Settings
# The model IDs come from the Bedrock console → Model catalog.
# Claude 3.5 Sonnet is the most capable; Titan is AWS-native and cheaper.
# -----------------------------------------------------------------------------
BEDROCK_LLM_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0

# -----------------------------------------------------------------------------
# OpenAI Settings
# Get your API key from: https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_LLM_MODEL=gpt-4o
OPENAI_EMBED_MODEL=text-embedding-3-small

# -----------------------------------------------------------------------------
# LLM Provider Selection
# Controls which provider is used by default.
# Options: "bedrock" | "openai"
# This can be overridden per-request by passing "provider" in the API body.
# -----------------------------------------------------------------------------
DEFAULT_LLM_PROVIDER=bedrock

# -----------------------------------------------------------------------------
# ChromaDB Settings
# CHROMA_PERSIST_DIR → local folder where ChromaDB saves its data files.
# CHROMA_COLLECTION_NAME → default collection name for document embeddings.
# EMBEDDING_PROVIDER → which provider to use for generating embeddings.
#   Options: "bedrock" | "openai" | "local" (local = sentence-transformers)
# -----------------------------------------------------------------------------
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION_NAME=documents
EMBEDDING_PROVIDER=bedrock

# -----------------------------------------------------------------------------
# AWS Cognito Settings (Authentication)
# COGNITO_USER_POOL_ID → found in AWS Console → Cognito → User Pools
# COGNITO_APP_CLIENT_ID → found in App clients tab of your User Pool
# COGNITO_REGION → usually same as AWS_REGION
# The JWKS URL is constructed automatically from pool ID + region.
# -----------------------------------------------------------------------------
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
COGNITO_APP_CLIENT_ID=your-app-client-id
COGNITO_REGION=us-east-1

# -----------------------------------------------------------------------------
# API Key Authentication
# A simple comma-separated list of pre-hashed API keys for MVP.
# Format: name:bcrypt_hash:role  (role = admin | user)
# Use the /auth/api-key endpoint to generate these in production.
# -----------------------------------------------------------------------------
API_KEYS_FILE=./api_keys.json

# -----------------------------------------------------------------------------
# Rate Limiting
# Maximum number of requests per user per minute across all protected endpoints.
# -----------------------------------------------------------------------------
RATE_LIMIT_PER_MINUTE=60

# -----------------------------------------------------------------------------
# Tavily Search (Web Search Tool)
# Get your free API key from: https://app.tavily.com
# Used by the Tool Agent to search the web.
# -----------------------------------------------------------------------------
TAVILY_API_KEY=tvly-your-tavily-api-key

# -----------------------------------------------------------------------------
# App Settings
# APP_ENV     → "development" | "staging" | "production"
#               Controls log format (pretty in dev, JSON in prod).
# LOG_LEVEL   → "DEBUG" | "INFO" | "WARNING" | "ERROR"
# APP_TITLE   → displayed in FastAPI's auto-generated /docs page
# CORS_ORIGINS → comma-separated list of allowed frontend origins
# -----------------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=DEBUG
APP_TITLE=Multi-Agent RAG Chatbot
APP_VERSION=1.0.0
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
