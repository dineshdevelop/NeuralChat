# =============================================================================
# .gitignore — Files to NOT commit to version control
# =============================================================================

# Environment files — contain secrets!
.env
.env.local
.env.*.local
api_keys.json

# Python
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/

# Virtual environment
venv/
.venv/
env/
ENV/

# ChromaDB persistent data — can be large, regenerate from documents
chroma_data/

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Terraform state — contains sensitive resource IDs
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.backup
terraform/*.tfplan
terraform/.terraform.lock.hcl

# Test artifacts
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# Logs
*.log
logs/

# Docker
*.tar

# Jupyter (if used for experiments)
.ipynb_checkpoints/
